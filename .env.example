# Database Configuration
# PostgreSQL 连接字符串 (用于 SQLAlchemy AsyncIO)
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/langgraph_db

# PostgreSQL 连接字符串 (用于 psycopg3 / LangGraph Checkpointer)
POSTGRES_URI=postgresql://postgres:CHANGE_ME@localhost:5432/langgraph_db

# Application Settings
APP_NAME=AI内容运营助手
DEBUG=true

# LLM Configuration (阿里百炼 OpenAI 兼容模式)
# 在此填写你的阿里百炼 API Key
LLM_API_KEY=your-aliyun-bailian-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 标准模型 (文章写作用，需要高质量输出)
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.7

# 快速模型 (选题生成、配图要点提取用，追求速度)
LLM_MODEL_FAST=qwen-turbo
LLM_TEMPERATURE_FAST=0.7
LLM_TEMPERATURE_EXTRACT=0.4

# LangSmith 配置 (追踪与监控)
# 启用 LangSmith 追踪
LANGCHAIN_TRACING_V2=false
# 你的 LangSmith API Key（请替换为你的实际 key）
LANGCHAIN_API_KEY=
# 项目名称（在 LangSmith 中显示）
LANGCHAIN_PROJECT=xiaohongshu-content-assistant
# LangSmith 端点（官方默认端点）
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ============== 日志配置 ==============
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志输出目标: file, loki, aliyun, volcengine
# 目前支持 file，后续可扩展云服务
LOG_TARGET=file

# 日志文件目录
LOG_DIR=logs

# 是否在控制台输出日志（开发时建议 true）
LOG_CONSOLE=false

# 控制台是否输出 JSON 格式（false 则彩色输出，开发友好）
LOG_JSON=false

# 是否启用 PII 脱敏（邮箱、信用卡、API Key、手机号）
LOG_PII_ANONYMIZE=true

# ============== 图片生成配置 (火山方舟) ==============
# 火山方舟 API Key
IMAGE_API_KEY=your-volcengine-ark-api-key
# API 基础地址
IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 图片生成模型
IMAGE_MODEL=doubao-seedream-4-5-251128
IMAGE_SIZE=1664x2240
IMAGE_RESPONSE_FORMAT=b64_json
IMAGE_WATERMARK=false
# 开发兜底：图片 API 失败时生成本地占位图；生产环境建议改为 false
IMAGE_LOCAL_FALLBACK=true
IMAGE_MAX_IMAGES=3
IMAGE_REQUEST_TIMEOUT=45
IMAGE_RETRY_ON_FAILURE=false
